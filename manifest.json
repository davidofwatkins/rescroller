{
  "name": "Rescroller",
  "version": "1.3",
  "version_name": "1.3",
  "manifest_version": 3,
  "description": "Decorate your scrollbars.",
  "icons": {
    "16": "appicons/icon16.png",
    "19": "appicons/icon19.png",
    "38": "appicons/icon38.png",
    "48": "appicons/icon48.png",
    "128": "appicons/icon128.png"
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Rescroller Settings",
    "default_icon": "appicons/icon19.png"
  },
  "background": {
    // @todo:david need to convert this to a service worker, which may be a little tricky. Will require converting background.js to a module and importing dependenceis there.
    // @see: https://developer.chrome.com/docs/extensions/mv3/mv3-migration/#man-sw
    // @see: https://developer.chrome.com/docs/extensions/mv3/migrating_to_service_workers/
    "scripts": [
      "js/jquery.js",
      "js/cssjson.js",
      "js/rescroller.js",
      "js/background.js"
    ],
    "persistant": false
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": ["http://*", "https://*", "file://*"],
  "web_accessible_resources": [
    {
      "resouces": [
        "images/defaults/up.png",
        "images/defaults/down.png",
        "images/defaults/left.png",
        "images/defaults/right.png"
      ],
      "matches": ["http://*", "https://*", "file://*"]
    }
  ]
}
